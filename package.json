{
    "name": "litelight-js",
    "version": "1.1.0",
    "description": "Zero-dependency vanilla JS lightbox for image galleries — touch, swipe, pinch-zoom, keyboard nav, TypeScript. npm install litelight-js. Under 10KB.",
    "main": "dist/lite-light.umd.min.js",
    "module": "dist/lite-light.min.js",
    "style": "dist/lite-light.min.css",
    "type": "module",
    "files": [
        "dist",
        "lite-light.js",
        "lite-light.css",
        "lite-light.d.ts",
        "README.md",
        "AGENTS.md",
        "llms.txt",
        "llms-full.txt",
        "ai.txt",
        "docs/CHANGELOG.md"
    ],
    "exports": {
        ".": {
            "types": "./dist/lite-light.d.ts",
            "import": "./dist/lite-light.min.js",
            "require": "./dist/lite-light.umd.min.js"
        },
        "./css": {
            "default": "./dist/lite-light.min.css"
        },
        "./dist/lite-light.min.css": "./dist/lite-light.min.css",
        "./AGENTS.md": "./AGENTS.md",
        "./llms.txt": "./llms.txt",
        "./llms-full.txt": "./llms-full.txt",
        "./ai.txt": "./ai.txt",
        "./package.json": "./package.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/byronjohnson/litelight.git"
    },
    "homepage": "https://litelightbox.com",
    "bugs": {
        "url": "https://github.com/byronjohnson/litelight/issues"
    },
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "dev": "vite build --watch",
        "build": "vite build",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "lightbox",
        "vanilla-js",
        "vanilla-js-lightbox",
        "javascript-lightbox",
        "js-lightbox",
        "image-lightbox",
        "image-gallery",
        "gallery",
        "images",
        "modal",
        "photo-viewer",
        "zero-dependencies",
        "no-jquery",
        "lightweight",
        "mobile-friendly",
        "touch",
        "swipe",
        "pinch-zoom",
        "esm",
        "typescript",
        "litelight",
        "litelight-js",
        "responsive",
        "accessible"
    ],
    "author": "Byron Johnson",
    "license": "MIT",
    "devDependencies": {
        "lightningcss": "^1.31.1",
        "vite": "^6.3.5"
    }
}
